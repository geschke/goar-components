{
  "name": "goar-components",
  "author": "Ralf Geschke <ralf@kuerbis.org>",
  "description": "A Vue.js component library that offers the enhanced UI elements tables, select boxes, and toasts, fully integrated with Bootstrap",
  "license": "MIT",
  "version": "0.3.3",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/geschke/goar-components.git"
  },
  "keywords": [
    "Vue",
    "Vue.js",
    "components",
    "library",
    "datatable",
    "toasts",
    "select",
    "bootstrap",
    "front-end"
  ],
  "peerDependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "vue": "^3.5.0",
    "pinia": "^3.0.0"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bootstrap": "^5.2.10",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vue-tsc": "^3.2.4",
    "vue": "^3.5.28",
    "pinia": "^3.0.4"
  },
  "main": "./dist/goar-components.cjs",
  "module": "./dist/goar-components.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/goar-components.es.js",
      "require": "./dist/goar-components.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && vite build && vue-tsc -p tsconfig.build.json",
    "typecheck": "vue-tsc -p tsconfig.build.json --noEmit",
    "dev": "vite",
    "preview": "vite preview",
    "preserve": "vite build",
    "serve": "vite preview --port 5050",
    "test": "exit 0"
  }
}